<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <!-- ConstraintLayout для визитки -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Карточка визитки -->
        <androidx.cardview.widget.CardView
            android:id="@+id/business_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="16:9">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <!-- Телефон -->
                <TextView
                    android:id="@+id/phone_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/garamond_classico_sc"
                    android:text="+7 (999) 123-45-67"
                    android:textColor="#000"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Логотип -->
                <ImageView
                    android:id="@+id/logo"
                    android:layout_width="93dp"
                    android:layout_height="19dp"
                    android:contentDescription="Company Logo"
                    android:src="@drawable/logo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Имя и должность -->
                <LinearLayout
                    android:id="@+id/name_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toTopOf="@+id/telegram_info"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5">

                    <TextView
                        android:id="@+id/full_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/garamond_classico_sc"
                        android:gravity="center"
                        android:text="Patrick BATEMAN"
                        android:textColor="#000"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/position"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/garamond_classico_sc"
                        android:gravity="center"
                        android:text="Vice President"
                        android:textColor="#666"
                        android:textSize="18sp" />

                </LinearLayout>

                <!-- Telegram и город -->
                <TextView
                    android:id="@+id/telegram_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/garamond_classico_sc"
                    android:text="@psychoamerican | New York City"
                    android:textColor="#000"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- НОВЫЙ BottomSheet -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:elevation="12dp"
        android:padding="24dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"> <!-- ДОБАВИЛ ЭТО -->

        <!-- Тянущий маркер -->
        <View
            android:layout_width="50dp"
            android:layout_height="6dp"
            android:layout_gravity="center"
            android:background="@drawable/drag_handle"
            android:layout_marginBottom="16dp"/>

        <!-- Фото -->
        <ImageView
            android:id="@+id/photo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/photo"
            android:scaleType="centerCrop"
    	    android:background="@drawable/circle_background"
            android:padding="0dp"
            android:contentDescription="Profile Photo"
	    android:clipToOutline="true"/>

        <!-- Email -->
        <TextView
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="patrick.bateman@dorseygroup.com"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="#555555"/>

        <!-- Интересы -->
        <TextView
            android:id="@+id/interests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Интересы: мода, финансы. Он одержим внешним видом и социальной позицией, любит роскошь и внимание к деталям."
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#777777"/>

        <!-- Навыки -->
        <TextView
            android:id="@+id/skills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Навыки: манипуляции, психология, мение скрывать свои настоящие намерения, организованности и хладнокровие, особенно в жестких ситуациях."
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#777777"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
