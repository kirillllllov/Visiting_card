<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <!-- Profile photo — left side, vertically centered -->
    <ImageView
        android:id="@+id/card_photo"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/circle_background"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:src="@drawable/photo"
        android:contentDescription="Profile Photo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Company logo — top right -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="80dp"
        android:layout_height="16dp"
        android:contentDescription="Company Logo"
        android:src="@drawable/logo_for_light_theme"
        android:scaleType="fitEnd"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Name + Position block — right of photo, centered -->
    <LinearLayout
        android:id="@+id/name_position"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/card_photo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/phone_number"
        app:layout_constraintVertical_bias="0.55">

        <TextView
            android:id="@+id/full_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/garamond_classico_sc"
            android:text="Имя Фамилия"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/garamond_classico_sc"
            android:layout_marginTop="2dp"
            android:text="Должность"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Phone — bottom, right of photo -->
    <TextView
        android:id="@+id/phone_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/garamond_classico_sc"
        android:text="+7 (999) 123-45-67"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintStart_toEndOf="@id/card_photo"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Social — bottom right -->
    <TextView
        android:id="@+id/telegram_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/garamond_classico_sc"
        android:text="@username"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
